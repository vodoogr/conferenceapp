# ============================================================
# ConferenceApp — Variables de Entorno
# Copia este archivo como .env.local para desarrollo
# En Vercel: Settings → Environment Variables
# ============================================================

# ── BASE DE DATOS ────────────────────────────────────────────
# NeonDB → Dashboard → tu proyecto → Connection string
# Formato: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST.neon.tech/conferenceapp?sslmode=require

# ── JWT ──────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERA_UN_STRING_ALEATORIO_DE_64_BYTES_AQUI

# ── GOOGLE AI (ya lo tienes) ─────────────────────────────────
# Google AI Studio → aistudio.google.com → Get API key
GOOGLE_AI_API_KEY=AIzaSy_TU_API_KEY_DE_AI_STUDIO

# ── GOOGLE OAUTH (pendiente configurar) ──────────────────────
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Tipo: Web Application
# Authorized redirect URIs: https://tuapp.vercel.app/api/auth/callback
GOOGLE_CLIENT_ID=XXXXXXXX.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-XXXXXXXX
GOOGLE_REDIRECT_URI=https://tuapp.vercel.app/api/auth/callback

# ── URLS ─────────────────────────────────────────────────────
# En desarrollo: http://localhost:5173
# En producción: tu dominio de Vercel
FRONTEND_URL=https://tuapp.vercel.app

# ============================================================
# CHECKLIST DE CONFIGURACIÓN
# ============================================================
# [ ] 1. NeonDB: crear proyecto → copiar DATABASE_URL
# [ ] 2. NeonDB: ejecutar sql/schema.sql en el SQL Editor
# [ ] 3. Google Cloud Console: crear proyecto (o usar existente)
# [ ] 4. Google Cloud Console: habilitar APIs:
#         - Google Drive API
#         - Cloud Speech-to-Text API (para V2)
# [ ] 5. Google Cloud Console: crear OAuth 2.0 Client ID
# [ ] 6. Añadir todas estas variables en Vercel → Settings → Environment Variables
# [ ] 7. Hacer deploy desde GitHub
